{
  "family": "ai-recruiter-interview",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::090605004529:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::090605004529:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "ai-recruiter-interview",
      "image": "090605004529.dkr.ecr.eu-central-1.amazonaws.com/ai-recruiter-backend:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "eu-central-1"
        },
        {
          "name": "SESSION_TABLE",
          "value": "InterviewSessions"
        },
        {
          "name": "USE_HTTPS",
          "value": "false"
        },
        {
          "name": "SES_FROM_EMAIL",
          "value": "Khaled.twich@hotmail.com"
        },
        {
          "name": "LINK_SECRET",
          "value": "ai-recruiter-link-secret-v1-eu-central-1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-recruiter-interview",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
