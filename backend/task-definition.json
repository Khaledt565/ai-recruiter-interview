{
  "family": "ai-recruiter-interview",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::090605004529:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::090605004529:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "interview-server",
      "image": "090605004529.dkr.ecr.eu-central-1.amazonaws.com/ai-recruiter-interview:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "eu-central-1"
        },
        {
          "name": "SESSION_TABLE",
          "value": "InterviewSessions"
        },
        {
          "name": "BEDROCK_MODEL_ID",
          "value": "anthropic.claude-3-haiku-20240307-v1:0"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-recruiter-interview",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
