[
  {
    "name": "ai-recruiter-backend",
    "image": "090605004529.dkr.ecr.eu-central-1.amazonaws.com/ai-recruiter-backend:latest",
    "portMappings": [
      {
        "containerPort": 8080,
        "hostPort": 8080,
        "protocol": "tcp"
      }
    ],
    "essential": true,
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/ai-recruiter-interview",
        "awslogs-region": "eu-central-1",
        "awslogs-stream-prefix": "ecs"
      }
    },
    "environment": [
      {
        "name": "USE_HTTPS",
        "value": "true"
      }
    ]
  }
]
